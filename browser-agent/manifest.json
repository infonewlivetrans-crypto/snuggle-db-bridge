{
  "manifest_version": 3,
  "name": "Radius Track Browser Agent (dev)",
  "version": "0.2.0",
  "description": "Dev-расширение Радиус Трек. Работает поверх открытого сайта ATI в браузере пользователя. API ATI не используется. Cookies и пароли ATI не читаются.",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "https://ati.su/*",
    "https://radius-track.ru/*",
    "https://www.radius-track.ru/*",
    "https://snuggle-db-bridge.lovable.app/*",
    "https://id-preview--d0d5cb47-0414-4a28-a4e9-a8beda3d2828.lovable.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["https://ati.su/loads/*", "https://ati.su/loadinfo/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://radius-track.ru/*",
        "https://www.radius-track.ru/*",
        "https://snuggle-db-bridge.lovable.app/*",
        "https://id-preview--d0d5cb47-0414-4a28-a4e9-a8beda3d2828.lovable.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["web-bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Radius Track Agent",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
