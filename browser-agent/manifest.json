{
  "manifest_version": 3,
  "name": "Radius Track Browser Agent (dev skeleton)",
  "version": "0.0.1",
  "description": "Dev skeleton. Работает поверх открытого сайта ATI в браузере пользователя. API ATI не используется.",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["https://ati.su/*"],
  "background": { "service_worker": "src/background.js", "type": "module" },
  "content_scripts": [
    { "matches": ["https://ati.su/*"], "js": ["src/content.js"], "run_at": "document_idle" }
  ],
  "action": { "default_title": "Radius Track Agent" }
}
